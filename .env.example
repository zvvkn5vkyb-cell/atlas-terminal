# Market data provider mode.
# Options: mock (default) | polygon
# Set to "polygon" and supply VITE_POLYGON_API_KEY to enable live US equity data.
VITE_MARKET_PROVIDER=mock

# Polygon.io API key — required when VITE_MARKET_PROVIDER=polygon.
# Get a free key at https://polygon.io (free tier gives 15-min delayed data).
# Leave blank to stay in mock mode even if VITE_MARKET_PROVIDER=polygon.
VITE_POLYGON_API_KEY=

# Financial Modeling Prep API key — enables fundamentals (P/E, EPS, Beta, etc.) and news.
# Get a free key at https://financialmodelingprep.com/developer (250 calls/day free tier).
# Leave blank to show stub placeholders in Security Detail.
VITE_FMP_API_KEY=
